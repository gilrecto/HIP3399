{% comment %}
  Renders free shipping progress banner

  Usage:
  {% render 'cart-free-shipping-banner' %}
{% endcomment %}

{%- if settings.show_free_shipping_banner -%}
  {%- liquid
    assign threshold = settings.free_shipping_threshold | times: 100
    assign current_total = cart.total_price
    assign remaining = threshold | minus: current_total
    assign progress_percentage = current_total | times: 100 | divided_by: threshold
    
    if progress_percentage > 100
      assign progress_percentage = 100
    endif
    
    assign qualified = false
    if remaining <= 0
      assign qualified = true
    endif
  -%}

  <div 
    class="cart-free-shipping-banner drawer-width" 
    data-threshold="{{ threshold }}"
    data-qualified="{{ qualified }}"
    style="
      --free-shipping-bg: {{ settings.free_shipping_banner_bg }};
      --free-shipping-text: {{ settings.free_shipping_banner_text }};
      --free-shipping-progress: {{ settings.free_shipping_progress_bar }};
    "
  >
    <div class="cart-free-shipping-banner__content">
      {%- if qualified -%}
        <p class="cart-free-shipping-banner__message cart-free-shipping-banner__message--qualified">
          {% comment %} <span class="cart-free-shipping-banner__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16.6667 5L7.50004 14.1667L3.33337 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span> {% endcomment %}
          {{ settings.free_shipping_message_reached }}
        </p>
      {%- else -%}
        {%- assign remaining_money = remaining | money_without_trailing_zeros -%}
        {%- assign message = settings.free_shipping_message_below | replace: '{amount}', remaining_money -%}
        <p class="cart-free-shipping-banner__message">
          {% comment %} <span class="cart-free-shipping-banner__icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.3333 1.66669V5.00002M6.66667 1.66669V5.00002M2.5 8.33335H17.5M4.16667 3.33335H15.8333C16.7538 3.33335 17.5 4.07955 17.5 5.00002V16.6667C17.5 17.5872 16.7538 18.3334 15.8333 18.3334H4.16667C3.24619 18.3334 2.5 17.5872 2.5 16.6667V5.00002C2.5 4.07955 3.24619 3.33335 4.16667 3.33335Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span> {% endcomment %}
          <span class="cart-free-shipping-banner__text">{{ message }}</span>
        </p>
      {%- endif -%}
      
      {%- if settings.show_free_shipping_progress_bar -%}
        <div class="cart-free-shipping-banner__progress-wrapper">
          <div 
            class="cart-free-shipping-banner__progress-bar ts:block!" 
            style="width: {{ progress_percentage }}%;"
            data-progress="{{ progress_percentage }}"
          ></div>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

