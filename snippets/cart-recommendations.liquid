{% comment %}
  Renders recommended products section for cart drawer

  Usage:
  {% render 'cart-recommendations' %}
{% endcomment %}

{%- if settings.show_cart_recommendations and cart.items.size > 0 -%}
  {%- liquid
    assign last_item = cart.items | last
    assign last_product_id = last_item.product_id
    assign limit = settings.cart_recommendations_limit | default: 3
  -%}

  <product-recommendations
    class="cart-recommendations"
    data-url="{{ routes.product_recommendations_url }}?limit={{ limit }}"
    data-section-id="cart-drawer"
    data-product-id="{{ last_product_id }}"
  >
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      <div class="cart-recommendations__header drawer-width">
        <h3 class="cart-recommendations__heading">{{ settings.cart_recommendations_heading | default: "You may also like" }}</h3>
      </div>

      <div class="cart-recommendations__content drawer-width">
        <div class="cart-recommendations__slider">
          <div class="cart-recommendations__products grid product-grid">
            {%- assign skip_card_product_styles = false -%}
            {%- for product in recommendations.products -%}
              <div class="cart-recommendations__product grid__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: 'square',
                  show_secondary_image: false,
                  show_vendor: false,
                  show_rating: false,
                  extend_height: false,
                  lazy_load: true,
                  skip_styles: skip_card_product_styles
                %}
              </div>
              {%- assign skip_card_product_styles = true -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  </product-recommendations>
{%- endif -%}

