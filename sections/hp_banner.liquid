				"default": 0,
				"min": 0,
				"max": 10,
				"step": 0.1,
				"unit": "rem"
			}
		],
		"blocks": [
			{
				"type": "heading",
				"name": "Heading",
				"limit": 3,
				"settings": [
					{
						"type": "select",
						"id": "type",
						"label": "Type",
						"options": [
							{
								"value": "title",
								"label": "Title"
							},
							{
								"value": "body",
								"label": "Body"
							},
							{
								"value": "caption",
								"label": "Caption"
							}
						],
