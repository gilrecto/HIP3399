					},
					{
						"type": "text",
						"id": "button_text",
						"label": "Button Text",
						"default": "Button"
					},
					{
						"type": "select",
						"id": "btn_style",
						"label": "Button Style",
						"options": [
							{
								"value": "button--primary",
								"label": "Primary"
							},
							{
								"value": "button--secondary",
								"label": "Secondary"
