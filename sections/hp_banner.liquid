				"step": 0.5,
				"unit": "rem"
			},
			{
				"type": "range",
				"id": "top_spacing_mobile",
				"label": "Mobile Top Spacing",
				"default": 0,
				"min": 0,
				"max": 10,
				"step": 0.1,
				"unit": "rem"
			},
			{
				"type": "range",
				"id": "bottom_spacing_mobile",
