							},
							{
								"value": "ts:!text-sm",
								"label": "Small"
							},
							{
								"value": "ts:!text-xs",
								"label": "Extra Small"
							}
						],
						"default": "ts:!text-2xl"
					},
					{
						"type": "select",
						"id": "text_transform",
						"label": "Text Transform",
						"options": [
							{
